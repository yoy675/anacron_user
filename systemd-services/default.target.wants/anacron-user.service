[Unit]
Description=Anacron-user script service
After=graphical-session.target

[Service]
Type=simple
# Run the original script (make sure it's executable)
ExecStart=$HOME/.local/bin/anacron-user
# Restart if the process exits
Restart=on-failure
RestartSec=60
# Ensure it stays running across logouts
KillMode=process
# Make stdout/stderr go to the user journal
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
