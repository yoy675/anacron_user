#!/bin/bash

cd /home/$USER/.anacron/
LOG_FILE="anacron.log"
if [ -w $LOG_FILE ];then clean_log;fi
clean_log() {
	TEMP_FILE="anacron.log.tmp"
	WEEK_AGO=$(date -d "7 days ago" +%Y-%m-%d)

	# 1. Identify line numbers for the last 5 entries of each category to protect them
	# The -a flag handles the 'binary file' issue.
	PROTECTED_LINES=$( (
		grep -na "cron.yearly" "$LOG_FILE" | tail -n 5 | cut -d: -f1| awk '{print $0-1;print $0}'
		grep -na "cron.monthly" "$LOG_FILE" | tail -n 5 | cut -d: -f1| awk '{print $0-1;print $0}'
		grep -na "cron.weekly" "$LOG_FILE" | tail -n 5 | cut -d: -f1| awk '{print $0-1;print $0}'
		grep -na "cron.daily" "$LOG_FILE" | tail -n 5 | cut -d: -f1
		grep -na "cron.hourly" "$LOG_FILE" | tail -n 5 | cut -d: -f1
		grep -na "Checking 1 email account" "$LOG_FILE" | tail -n 5 | cut -d: -f1
	) | sort -nu )

	# 2. Use AWK to keep lines that are either:
	#    a) Newer than a week ago
	#    b) Part of the 'protected' last 5 entries
	# This maintains the original file order.
	awk -v limit="$WEEK_AGO" -v protected="$PROTECTED_LINES" -v text_flag="-a" '
	BEGIN {
		split(protected, p_array, "\n")
		for (i in p_array) p_map[p_array[i]] = 1
	}
	{
		# Extract date (assumes format YYYY-MM-DD at start of line or in INFO tags)
		match($0, /[0-9]{4}-[0-9]{2}-[0-9]{2}/)
		line_date = substr($0, RSTART, RLENGTH)

		if (line_date >= limit || NR in p_map || $0 == "") {
			print $0
		}
	}' "$LOG_FILE" > "$TEMP_FILE"

	mv "$TEMP_FILE" "$LOG_FILE"
}

for file in spool/anacron/*; do
	if sed '/^ \?#/d;/^ \?[A-Za-z_][A-Za-z0-9_]*=/d;/^$/d;s|#.*||g' anacrontab | awk '{print "spool/anacron/"$3}'| grep "$file" -q;then
		continue
	else
		trash "$file"
	fi
done
exit 0